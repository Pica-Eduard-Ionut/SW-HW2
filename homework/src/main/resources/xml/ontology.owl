<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/book-recommendation#"
     xml:base="http://example.org/book-recommendation"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://example.org/book-recommendation"/>
    <owl:ObjectProperty rdf:about="http://example.org/book-recommendation#hasReadingLevel">
        <rdfs:domain rdf:resource="http://example.org/book-recommendation#User"/>
        <rdfs:range rdf:resource="http://example.org/book-recommendation#ReadingLevel"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/book-recommendation#hasTheme">
        <rdfs:domain rdf:resource="http://example.org/book-recommendation#Book"/>
        <rdfs:range rdf:resource="http://example.org/book-recommendation#Theme"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/book-recommendation#prefersTheme">
        <rdfs:domain rdf:resource="http://example.org/book-recommendation#User"/>
        <rdfs:range rdf:resource="http://example.org/book-recommendation#Theme"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/book-recommendation#recommendedTo">
        <rdfs:domain rdf:resource="http://example.org/book-recommendation#Book"/>
        <rdfs:range rdf:resource="http://example.org/book-recommendation#User"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/book-recommendation#suitableFor">
        <rdfs:domain rdf:resource="http://example.org/book-recommendation#Book"/>
        <rdfs:range rdf:resource="http://example.org/book-recommendation#ReadingLevel"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/book-recommendation#writtenBy">
        <rdfs:domain rdf:resource="http://example.org/book-recommendation#Book"/>
        <rdfs:range rdf:resource="http://example.org/book-recommendation#Author"/>
    </owl:ObjectProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/book-recommendation#name">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/book-recommendation#title">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    <owl:Class rdf:about="http://example.org/book-recommendation#Author"/>
    <owl:Class rdf:about="http://example.org/book-recommendation#Book"/>
    <owl:Class rdf:about="http://example.org/book-recommendation#ReadingLevel"/>
    <owl:Class rdf:about="http://example.org/book-recommendation#RecommendedBook">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://example.org/book-recommendation#Book"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://example.org/book-recommendation#hasTheme"/>
                        <owl:someValuesFrom rdf:resource="http://example.org/book-recommendation#Theme"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://example.org/book-recommendation#suitableFor"/>
                        <owl:someValuesFrom rdf:resource="http://example.org/book-recommendation#ReadingLevel"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/book-recommendation#Theme"/>
    <owl:Class rdf:about="http://example.org/book-recommendation#User"/>
    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Advanced">
        <rdf:type rdf:resource="http://example.org/book-recommendation#ReadingLevel"/>
        <name>Advanced</name>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#AlexMichaelides">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Author"/>
        <name>Alex Michaelides</name>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Alice">
        <rdf:type rdf:resource="http://example.org/book-recommendation#User"/>
        <hasReadingLevel rdf:resource="http://example.org/book-recommendation#Intermediate"/>
        <prefersTheme rdf:resource="http://example.org/book-recommendation#ScienceFiction"/>
        <name>Alice</name>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Beginner">
        <rdf:type rdf:resource="http://example.org/book-recommendation#ReadingLevel"/>
        <name>Beginner</name>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Bob">
        <rdf:type rdf:resource="http://example.org/book-recommendation#User"/>
        <hasReadingLevel rdf:resource="http://example.org/book-recommendation#Beginner"/>
        <prefersTheme rdf:resource="http://example.org/book-recommendation#Mystery"/>
        <name>Bob</name>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Dune">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Book"/>
        <hasTheme rdf:resource="http://example.org/book-recommendation#Fantasy"/>
        <hasTheme rdf:resource="http://example.org/book-recommendation#ScienceFiction"/>
        <suitableFor rdf:resource="http://example.org/book-recommendation#Advanced"/>
        <writtenBy rdf:resource="http://example.org/book-recommendation#FrankHerbert"/>
        <title>Dune</title>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Fantasy">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Theme"/>
        <name>Fantasy</name>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#FrankHerbert">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Author"/>
        <name>Frank Herbert</name>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#HungerGames">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Book"/>
        <hasTheme rdf:resource="http://example.org/book-recommendation#Fantasy"/>
        <hasTheme rdf:resource="http://example.org/book-recommendation#ScienceFiction"/>
        <suitableFor rdf:resource="http://example.org/book-recommendation#Beginner"/>
        <writtenBy rdf:resource="http://example.org/book-recommendation#SuzanneCollins"/>
        <title>Hunger Games</title>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Intermediate">
        <rdf:type rdf:resource="http://example.org/book-recommendation#ReadingLevel"/>
        <name>Intermediate</name>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Murder">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Theme"/>
        <name>Murder</name>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Mystery">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Theme"/>
        <name>Mystery</name>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#ScienceFiction">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Theme"/>
        <name>Science Fiction</name>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#SuzanneCollins">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Author"/>
        <name>Suzanne Collins</name>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#TheSilentPatient">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Book"/>
        <hasTheme rdf:resource="http://example.org/book-recommendation#Murder"/>
        <hasTheme rdf:resource="http://example.org/book-recommendation#Mystery"/>
        <suitableFor rdf:resource="http://example.org/book-recommendation#Intermediate"/>
        <writtenBy rdf:resource="http://example.org/book-recommendation#AlexMichaelides"/>
        <title>The Silent Patient</title>
    </owl:NamedIndividual>
</rdf:RDF>
