<?xml version="1.0"?>

<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:ex="http://example.org/book-recommendation#">

    <owl:Ontology rdf:about="http://example.org/book-recommendation"/>

    <owl:Class rdf:about="http://example.org/book-recommendation#User"/>
    <owl:Class rdf:about="http://example.org/book-recommendation#Book"/>

    <owl:ObjectProperty rdf:about="http://example.org/book-recommendation#prefersTheme"/>

    <owl:DatatypeProperty rdf:about="http://example.org/book-recommendation#title"/>
    <owl:DatatypeProperty rdf:about="http://example.org/book-recommendation#author"/>
    <owl:DatatypeProperty rdf:about="http://example.org/book-recommendation#theme"/>
    <owl:DatatypeProperty rdf:about="http://example.org/book-recommendation#readingLevel"/>

</rdf:RDF>